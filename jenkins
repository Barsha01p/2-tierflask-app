pipeline {
    agent any

    environment {
        // Target Flask Application Server Info
        APP_SERVER_IP  = '54.89.235.35' // <-- Replace with your Flask EC2 Public IP
        APP_SERVER_USER = 'ubuntu'
        
        // Secure AWS database tier variables
        DB_HOST         = '://amazonaws.com'
        DB_NAME         = 'flask_db'
    }

    stages {
        stage('1. Checkout Code from GitHub') {
            steps {
                // Jenkins automatically pulls the Git directory structure here
                checkout scm
            }
        }

        stage('2. Code Environment Verification') {
            steps {
                // Isolates Python environment and installs packages to test syntax errors
                sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt
                    echo "Syntax check passed successfully!"
                '''
            }
        }

        stage('3. Deploy to Flask Application EC2') {
            steps {
                // Uses the secret SSH key saved inside Jenkins to run remote terminal updates
                sshagent(['aws-flask-ssh-key']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ${APP_SERVER_USER}@${APP_SERVER_IP} "
                            mkdir -p ~/flask-app && cd ~/flask-app
                            
                            # Fetch the updated source code straight from GitHub
                            if [ -d .git ]; then git pull; else git clone https://github.com .; fi
                            
                            # Reset background runtime dependencies 
                            python3 -m venv venv
                            . venv/bin/activate
                            pip install -r requirements.txt
                            
                            # Restart the background process manager to make changes live
                            sudo systemctl restart flaskapp.service || nohup python3 app.py > app.log 2>&1 &
                        "
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Deployment Complete! Pipeline successfully finished running tasks.'
        }
        failure {
            echo 'Deployment Pipeline failed. Please check build logs for debugging.'
        }
    }
}
